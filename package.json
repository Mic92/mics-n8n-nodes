{
  "name": "mics-n8n-nodes",
  "version": "1.0.0",
  "description": "Mic's custom n8n community nodes",
  "keywords": [
    "n8n-community-node-package",
    "n8n"
  ],
  "license": "MIT",
  "author": {
    "name": "Jörg Thalheim",
    "email": "joerg@thalheim.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mic92/mics-n8n-nodes.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials test --write",
    "lint": "eslint 'nodes/**/*.ts' 'test/**/*.ts'",
    "lintfix": "eslint 'nodes/**/*.ts' 'test/**/*.ts' --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/nodes/OpenCrow/OpenCrow.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^2.10.2",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
